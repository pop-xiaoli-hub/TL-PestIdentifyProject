platform :ios, '12.0'

target 'TL-PestIdentify' do
  pod 'LookinServer', :configurations => ['Debug']
  pod 'YYModel'
  pod 'AgriPestClient', :git => 'https://github.com/lukecc00/AgriPest-IOS-SDK.git', :tag => 'v1.0.105'
  pod 'WCDB.objc', :git => 'https://github.com/Tencent/wcdb.git', :branch => 'master'
  pod 'Masonry'
  pod 'SDWebImage', '~> 5.0'
end

# Xcode 26 兼容
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # AFNetworking: Xcode 26 netinet6/in6.h private header 问题
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      if target.name == 'AFNetworking'
        flags = config.build_settings['OTHER_CFLAGS'] || ['$(inherited)']
        flags << '-fno-modules'
        config.build_settings['OTHER_CFLAGS'] = flags
      end
    end
  end
end
